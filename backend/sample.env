# Node.js Application Configuration

# Application port  
PORT=3000
ENCRYPTION_SALT=your_encryption_salt_here

# JWT Authentication
JWT_SECRET=your_secure_jwt_secret_key_here
REFRESH_TOKEN_PEPPER=your_strong_random_pepper_for_refresh_tokens_here

# Allowed CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=coffee_club_db
DB_TABLE_PREFIX=cc_

# Email configuration
MAIL_HOST=smtp.gmail.com
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@coffeeclub.com
FRONTEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:4200

# SMS configuration
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=your_sms_sender_id

# WhatsApp (Baileys)
WHATSAPP_AUTH_DIR=./whatsapp-auth

# Google Drive Backup (OAuth2 — set once for the platform)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret